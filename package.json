{
  "name": "virtual-desktop",
  "version": "1.0.0",
  "description": "A small app that allows shortcuts to be grouped by category.  Each category is an expansion panel that can be defaulted to open or closed, creating a task-focused experience.  Designed for users that need to maintain deeply-nested, rigid folder-structures.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "auto-launch": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0"
  },
  "overrides": {
    "app-builder-lib": {
      "@noble/hashes": "1.4.0"
    },
    "@noble/hashes": "1.3.3"
  },
  "build": {
    "appId": "com.stray.virtualdesktop",
    "productName": "Virtual Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": false,
      "shortcutName": "Virtual Desktop"
    }
  }
}